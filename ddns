#!/bin/bash

# 输出字体颜色
GREEN="\033[32m"
RED="\033[31m"
YELLOW="\033[0;33m"
NC="\033[0m"
GREEN_ground="\033[42;37m" # 全局绿色
RED_ground="\033[41;37m"   # 全局红色
Info="${GREEN}[信息]${NC}"
Error="${RED}[错误]${NC}"
Tip="${YELLOW}[提示]${NC}"

cop_info(){
clear
echo -e "${GREEN}######################################
#      ${RED} DDNS 一键脚本 v2.6 (智能升级版)${GREEN}#
#             作者: 末晨 / 优化      ${GREEN}#
#       ${GREEN}https://blog.mochen.one      ${GREEN}#
######################################${NC}"
echo
}

if ! grep -qiE "debian|ubuntu|alpine" /etc/os-release; then
    echo -e "${RED}本脚本仅支持 Debian、Ubuntu 或 Alpine 系统，请在这些系统上运行。${NC}"
    exit 1
fi

if [[ $(whoami) != "root" ]]; then
    echo -e "${Error}请以root身份执行该脚本！"
    exit 1
fi

check_curl() {
    if ! command -v curl &>/dev/null; then
        echo -e "${YELLOW}未检测到 curl，正在安装 curl...${NC}"
        if grep -qiE "debian|ubuntu" /etc/os-release; then
            apt update && apt install -y curl
        elif grep -qiE "alpine" /etc/os-release; then
            apk update && apk add curl
        fi
    fi
    if grep -qiE "alpine" /etc/os-release; then
        if ! grep --version 2>/dev/null | grep -q "GNU"; then
            apk update && apk add grep
        fi
    fi
}

# 提取核心逻辑为独立函数，方便覆盖升级
install_ddns_core(){
    cat <<'EOF' > /etc/DDNS/DDNS
#!/bin/bash
source /etc/DDNS/.config
LOG_FILE="/etc/DDNS/ddns.log"

write_log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
    tail -n 300 "$LOG_FILE" > "$LOG_FILE.tmp" && mv "$LOG_FILE.tmp" "$LOG_FILE"
}

# 如果是定时任务且IP未改变，则静默退出；如果是手动执行(force)，继续往下走
if [[ "$1" != "force" && "$Public_IPv4" == "$Old_Public_IPv4" && "$Public_IPv6" == "$Old_Public_IPv6" ]]; then
    exit 0
fi

write_log "============== 开始执行 DDNS 更新 =============="
if [[ -n "$Public_IPv4" && ( "$Public_IPv4" != "$Old_Public_IPv4" || "$1" == "force" ) ]]; then
    write_log "当前公网 IPv4: $Public_IPv4"
    for Domain in "${Domains[@]}"; do
        Root_domain=$(echo "$Domain" | awk -F '.' '{print $(NF-1)"."$NF}')
        
        # 获取 Zone ID
        Zone_id=$(curl -s -X GET "https://api.cloudflare.com/client/v4/zones?name=$Root_domain" -H "Authorization: Bearer $Api_Token" -H "Content-Type: application/json" | grep -Po '(?<="id":")[^"]*' | head -1)
        if [ -z "$Zone_id" ]; then
            write_log "❌ 失败: 无法获取 $Domain 的区域 ID (请检查 Token 是否有效或包含区域读取权限)"
            continue
        fi

        # 获取 DNS 记录 ID
        DNS_IDv4=$(curl -s -X GET "https://api.cloudflare.com/client/v4/zones/$Zone_id/dns_records?type=A&name=$Domain" -H "Authorization: Bearer $Api_Token" -H "Content-Type: application/json" | grep -Po '(?<="id":")[^"]*' | head -1)
        if [ -z "$DNS_IDv4" ]; then
            write_log "❌ 失败: 无法获取 $Domain 的 DNS 记录 ID (请先在CF后台手动添加一条任意IP的 A 记录)"
            continue
        fi
        
        # 更新记录
        HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" -X PUT "https://api.cloudflare.com/client/v4/zones/$Zone_id/dns_records/$DNS_IDv4" \
             -H "Authorization: Bearer $Api_Token" \
             -H "Content-Type: application/json" \
             --data "{\"type\":\"A\",\"name\":\"$Domain\",\"content\":\"$Public_IPv4\"}")
             
        if [ "$HTTP_CODE" == "200" ]; then
            write_log "✅ 成功: IPv4 域名 $Domain 已更新为 $Public_IPv4"
        else
            write_log "❌ 失败: IPv4 域名 $Domain 更新异常，HTTP状态码: $HTTP_CODE"
        fi
    done
elif [[ -z "$Public_IPv4" && "$1" == "force" ]]; then
    write_log "⚠️ 警告: 未能获取到本机的公网 IPv4 地址！"
fi

if [ "$ipv6_set" = "true" ]; then
    if [[ -n "$Public_IPv6" && ( "$Public_IPv6" != "$Old_Public_IPv6" || "$1" == "force" ) ]]; then
        write_log "当前公网 IPv6: $Public_IPv6"
        for Domainv6 in "${Domainsv6[@]}"; do
            Root_domainv6=$(echo "$Domainv6" | awk -F '.' '{print $(NF-1)"."$NF}')
            
            Zone_idv6=$(curl -s -X GET "https://api.cloudflare.com/client/v4/zones?name=$Root_domainv6" -H "Authorization: Bearer $Api_Token" -H "Content-Type: application/json" | grep -Po '(?<="id":")[^"]*' | head -1)
            if [ -z "$Zone_idv6" ]; then
                write_log "❌ 失败: 无法获取 $Domainv6 的区域 ID"
                continue
            fi

            DNS_IDv6=$(curl -s -X GET "https://api.cloudflare.com/client/v4/zones/$Zone_idv6/dns_records?type=AAAA&name=$Domainv6" -H "Authorization: Bearer $Api_Token" -H "Content-Type: application/json" | grep -Po '(?<="id":")[^"]*' | head -1)
            if [ -z "$DNS_IDv6" ]; then
                write_log "❌ 失败: 无法获取 $Domainv6 的 DNS 记录 ID (请先在CF后台手动添加一条任意IP的 AAAA 记录)"
                continue
            fi
            
            HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" -X PUT "https://api.cloudflare.com/client/v4/zones/$Zone_idv6/dns_records/$DNS_IDv6" \
                 -H "Authorization: Bearer $Api_Token" \
                 -H "Content-Type: application/json" \
                 --data "{\"type\":\"AAAA\",\"name\":\"$Domainv6\",\"content\":\"$Public_IPv6\"}")
                 
            if [ "$HTTP_CODE" == "200" ]; then
                write_log "✅ 成功: IPv6 域名 $Domainv6 已更新为 $Public_IPv6"
            else
                write_log "❌ 失败: IPv6 域名 $Domainv6 更新异常，HTTP状态码: $HTTP_CODE"
            fi
        done
    elif [[ -z "$Public_IPv6" && "$1" == "force" ]]; then
        write_log "⚠️ 警告: 开启了IPv6解析，但未能获取到本机的公网 IPv6 地址！"
    fi
fi

if [[ -n "$Telegram_Bot_Token" && -n "$Telegram_Chat_ID" && (("$Public_IPv4" != "$Old_Public_IPv4" && -n "$Public_IPv4") || ("$Public_IPv6" != "$Old_Public_IPv6" && -n "$Public_IPv6")) ]]; then
    send_telegram_notification
    write_log "已触发 Telegram 通知"
fi

if [[ -n "$Public_IPv4" && "$Public_IPv4" != "$Old_Public_IPv4" ]]; then
    sed -i "s/^Old_Public_IPv4=.*/Old_Public_IPv4=\"$Public_IPv4\"/" /etc/DDNS/.config
fi
if [[ -n "$Public_IPv6" && "$Public_IPv6" != "$Old_Public_IPv6" ]]; then
    sed -i "s/^Old_Public_IPv6=.*/Old_Public_IPv6=\"$Public_IPv6\"/" /etc/DDNS/.config
fi
EOF
    chmod +x /etc/DDNS/DDNS
}

install_ddns_config(){
    cat <<'EOF' > /etc/DDNS/.config
Domains=("your_domain1.com" "your_domain2.com")
ipv6_set="setting"
Domainsv6=("your_domainv6_1.com" "your_domainv6_2.com")
Api_Token="your_api_token"
Telegram_Bot_Token=""
Telegram_Chat_ID=""

regex_pattern='^(eth|ens|eno|esp|enp)[0-9]+'
InterFace=($(ip link show | awk -F': ' '{print $2}' | grep -E "$regex_pattern" | sed "s/@.*//g"))
Public_IPv4=""
Public_IPv6=""
Old_Public_IPv4=""
Old_Public_IPv6=""
ipv4Regex="^([0-9]{1,3}\.){3}[0-9]{1,3}$"
ipv6Regex="^([0-9a-fA-F]{1,4}:){7,7}[0-9a-fA-F]{1,4}|([0-9a-fA-F]{1,4}:){1,7}:|([0-9a-fA-F]{1,4}:){1,6}:[0-9a-fA-F]{1,4}|([0-9a-fA-F]{1,4}:){1,5}(:[0-9a-fA-F]{1,4}){1,2}|([0-9a-fA-F]{1,4}:){1,4}(:[0-9a-fA-F]{1,4}){1,3}|([0-9a-fA-F]{1,4}:){1,3}(:[0-9a-fA-F]{1,4}){1,4}|([0-9a-fA-F]{1,4}:){1,2}(:[0-9a-fA-F]{1,4}){1,5}|[0-9a-fA-F]{1,4}:((:[0-9a-fA-F]{1,4}){1,6})|:((:[0-9a-fA-F]{1,4}){1,7}|:)|fe80:(:[0-9a-fA-F]{0,4}){0,4}%[0-9a-zA-Z]{1,}|::(ffff(:0{1,4}){0,1}:){0,1}((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])\.){3,3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])|([0-9a-fA-F]{1,4}:){1,4}:((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])\.){3,3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])$"

if grep -qiE "debian|ubuntu" /etc/os-release; then
    for i in "${InterFace[@]}"; do
        ipv4=$(curl -s4 --max-time 3 --interface "$i" ip.sb -k | grep -E -v '^(2a09|104\.28)' || true)
        if [[ -z "$ipv4" ]]; then ipv4=$(curl -s4 --max-time 3 --interface "$i" https://api.ipify.org -k | grep -E -v '^(2a09|104\.28)' || true); fi
        if [[ -n "$ipv4" && "$ipv4" =~ $ipv4Regex ]]; then Public_IPv4="$ipv4"; fi

        if [[ "$ipv6_set" == "true" ]]; then
            ipv6=$(curl -s6 --max-time 3 --interface "$i" ip.sb -k | grep -E -v '^(2a09|104\.28)' || true)
            if [[ -z "$ipv6" ]]; then ipv6=$(curl -s6 --max-time 3 --interface "$i" https://api6.ipify.org -k | grep -E -v '^(2a09|104\.28)' || true); fi
            if [[ -n "$ipv6" && "$ipv6" =~ $ipv6Regex ]]; then Public_IPv6="$ipv6"; fi
        fi
    done
else
    ipv4=$(curl -s4 --max-time 3 ip.sb -k | grep -E -v '^(2a09|104\.28)' || true)
    if [[ -z "$ipv4" ]]; then ipv4=$(curl -s4 --max-time 3 https://api.ipify.org -k | grep -E -v '^(2a09|104\.28)' || true); fi
    if [[ -n "$ipv4" && "$ipv4" =~ $ipv4Regex ]]; then Public_IPv4="$ipv4"; fi

    if [[ "$ipv6_set" == "true" ]]; then
        ipv6=$(curl -s6 --max-time 3 ip.sb -k | grep -E -v '^(2a09|104\.28)' || true)
        if [[ -z "$ipv6" ]]; then ipv6=$(curl -s6 --max-time 3 https://api6.ipify.org -k | grep -E -v '^(2a09|104\.28)' || true); fi
        if [[ -n "$ipv6" && "$ipv6" =~ $ipv6Regex ]]; then Public_IPv6="$ipv6"; fi
    fi
fi

send_telegram_notification() {
    local message=""
    for domain in "${Domains[@]}"; do message+="$domain "; done
    message+="IPv4更新 $Old_Public_IPv4 🔜 $Public_IPv4 。"
    if [ "$ipv6_set" == "true" ]; then
        if [ "${Domains[*]}" != "${Domainsv6[*]}" ]; then
            for domainv6 in "${Domainsv6[@]}"; do message+="$domainv6 "; done
        fi
        message+="IPv6更新 $Old_Public_IPv6 🔜 $Public_IPv6 。"
    fi
    curl -s -X POST "https://api.telegram.org/bot$Telegram_Bot_Token/sendMessage" -d "chat_id=$Telegram_Chat_ID" -d "text=$message"
}
EOF
    chmod +x /etc/DDNS/.config
}

install_ddns(){
    if [ ! -f "/usr/bin/ddns" ]; then
        curl -o /usr/bin/ddns https://raw.githubusercontent.com/mocchen/cssmeihua/mochen/shell/ddns.sh && chmod +x /usr/bin/ddns
    fi
    mkdir -p /etc/DDNS
    install_ddns_config
    install_ddns_core
    echo -e "${Info}DDNS 安装完成！"
    echo
}

check_ddns_status() {
    if grep -qiE "alpine" /etc/os-release; then
        if crontab -l | grep -q "/bin/bash /etc/DDNS/DDNS"; then
            ddns_status=running
        else
            ddns_status=dead
        fi
    else
        if [[ -f "/etc/systemd/system/ddns.timer" ]]; then
            STatus=$(systemctl status ddns.timer | grep Active | awk '{print $3}' | cut -d "(" -f2 | cut -d ")" -f1)
            if [[ $STatus =~ "waiting" || $STatus =~ "running" ]]; then
                ddns_status=running
            else
                ddns_status=dead
            fi
        else
            ddns_status=not_installed
        fi
    fi
}

go_ahead(){
    echo -e "${Tip}选择一个选项：
  ${GREEN}0${NC}：退出
  ${GREEN}1${NC}：重启 DDNS
  ${GREEN}2${NC}：停止 DDNS
  ${GREEN}3${NC}：${RED}卸载 DDNS${NC}
  ${GREEN}4${NC}：修改要解析的域名
  ${GREEN}5${NC}：修改 Cloudflare Api (Token)
  ${GREEN}6${NC}：配置 Telegram 通知
  ${GREEN}7${NC}：更改 DDNS 运行时间
  ${GREEN}8${NC}：查看 DDNS 运行日志 (状态)
  ${GREEN}9${NC}：${YELLOW}立即手动执行并查看结果${NC}" 
    echo
    read -p "选项: " option
    until [[ "$option" =~ ^[0-9]$ ]]; do
        echo -e "${Error}请输入正确的数字 [0-9]"
        echo
        exit 1
    done
    case "$option" in
        0) exit 1 ;;
        1) restart_ddns ;;
        2) stop_ddns ;;
        3)
            if grep -qiE "alpine" /etc/os-release; then
                stop_ddns
                rm -rf /etc/DDNS /usr/bin/ddns
            else
                systemctl stop ddns.service >/dev/null 2>&1
                systemctl stop ddns.timer >/dev/null 2>&1
                rm -rf /etc/systemd/system/ddns.service /etc/systemd/system/ddns.timer /etc/DDNS /usr/bin/ddns
            fi
            echo -e "${Info}DDNS 已彻底卸载！"
            echo
        ;;
        4)
            set_domain
            restart_ddns
            sleep 2
            check_ddns_install
        ;;
        5)
            set_cloudflare_api
            restart_ddns
            sleep 2
            check_ddns_install
        ;;
        6)
            set_telegram_settings
            check_ddns_install
        ;;
        7)
            set_ddns_run_interval
            sleep 2
            check_ddns_install
        ;;
        8)
            echo -e "${Info}正在读取日志 (/etc/DDNS/ddns.log)..."
            echo "------------------------------------------------"
            if [ -f "/etc/DDNS/ddns.log" ]; then
                tail -n 20 /etc/DDNS/ddns.log
            else
                echo -e "${Tip}暂无日志。请按 9 强制触发一次更新即可生成日志。"
            fi
            echo "------------------------------------------------"
            echo
            read -p "按回车键返回主菜单..."
            check_ddns_install
        ;;
        9)
            echo -e "${Info}正在强制触发 DDNS 更新，请稍候 (约需 5-10 秒)..."
            bash /etc/DDNS/DDNS force
            echo -e "${Info}执行完毕！以下是最新执行结果："
            echo "------------------------------------------------"
            if [ -f "/etc/DDNS/ddns.log" ]; then
                tail -n 8 /etc/DDNS/ddns.log
            else
                echo -e "${Error}执行可能被意外中断，未生成日志。"
            fi
            echo "------------------------------------------------"
            echo
            read -p "按回车键返回主菜单..."
            check_ddns_install
        ;;
    esac
}

set_cloudflare_api(){
    echo -e "${Tip}开始配置CloudFlare API Token..."
    read -rp "令牌: " Api_Token_Input
    if [ -z "$Api_Token_Input" ]; then
        echo -e "${Error}未输入令牌，无法执行操作！"
        exit 1
    else
        API_TOKEN="$Api_Token_Input"
    fi
    echo -e "${Info}你的令牌：${RED_ground}${API_TOKEN}${NC}"
    sed -i '/^Email=/d' /etc/DDNS/.config 
    if grep -q "Api_Token=" /etc/DDNS/.config; then
        sed -i 's/^#\?Api_Token=".*"/Api_Token="'"${API_TOKEN}"'"/g' /etc/DDNS/.config
    else
        sed -i 's/^#\?Api_key=".*"/Api_Token="'"${API_TOKEN}"'"/g' /etc/DDNS/.config
    fi
}

set_domain() {
    ipv4_check=$(curl -s ip.sb -4)
    if [ -n "$ipv4_check" ]; then
        echo -e "${Tip}请输入您要解析的IPv4域名（多个请用逗号分隔） (或按回车跳过)"
        read -rp "IPv4域名: " Domain_input
        if [ -n "$Domain_input" ]; then
            Domain_input="${Domain_input//，/,}"
            IFS=',' read -ra Domains <<< "$Domain_input"
            sed -i '/^Domains=/c\Domains=('"${Domains[*]}"')' /etc/DDNS/.config
        fi
    fi

    ipv6_check=$(curl -s ip.sb -6)
    if [ -n "$ipv6_check" ]; then
        while true; do
            echo -e "${Tip}是否开启 IPv6 解析？(y/n)"
            read -rp "选择: " enable_ipv6
            if [[ "$enable_ipv6" =~ ^[Yy]$ ]]; then
                sed -i 's/^#\?ipv6_set=".*"/ipv6_set="true"/g' /etc/DDNS/.config
                echo -e "${Tip}请输入IPv6域名（多域名逗号分隔） (回车跳过)"
                read -rp "IPv6域名: " Domainv6_input
                if [ -n "$Domainv6_input" ]; then
                    Domainv6_input="${Domainv6_input//，/,}"
                    IFS=',' read -ra Domainsv6 <<< "$Domainv6_input"
                    sed -i '/^Domainsv6=/c\Domainsv6=('"${Domainsv6[*]}"')' /etc/DDNS/.config
                fi
                break
            elif [[ "$enable_ipv6" =~ ^[Nn]$ ]]; then
                sed -i 's/^#\?ipv6_set=".*"/ipv6_set="false"/g' /etc/DDNS/.config
                break
            fi
        done
    else
        sed -i 's/^#\?ipv6_set=".*"/ipv6_set="false"/g' /etc/DDNS/.config
    fi
}

set_telegram_settings(){
    echo -e "${Tip}请输入Telegram Bot Token，直接按 Enter 跳过"
    read -rp "Token: " Token
    if [ -n "$Token" ]; then
        echo -e "${Tip}请输入Telegram Chat ID"
        read -rp "Chat ID: " Chat_ID
        if [ -n "$Chat_ID" ]; then
            sed -i 's/^#\?Telegram_Bot_Token=".*"/Telegram_Bot_Token="'"${Token}"'"/g' /etc/DDNS/.config
            sed -i 's/^#\?Telegram_Chat_ID=".*"/Telegram_Chat_ID="'"${Chat_ID}"'"/g' /etc/DDNS/.config
        fi
    fi
}

run_ddns() {
    if grep -qiE "alpine" /etc/os-release; then
        if ! crontab -l | grep -q "/bin/bash /etc/DDNS/DDNS >/dev/null 2>&1"; then
            (crontab -l; echo "*/2 * * * * /bin/bash /etc/DDNS/DDNS >/dev/null 2>&1") | crontab -
        fi
    else
        service='[Unit]\nDescription=ddns\nAfter=network.target\n\n[Service]\nType=simple\nWorkingDirectory=/etc/DDNS\nExecStart=bash DDNS\n\n[Install]\nWantedBy=multi-user.target'
        timer='[Unit]\nDescription=ddns timer\n\n[Timer]\nOnUnitActiveSec=60s\nUnit=ddns.service\n\n[Install]\nWantedBy=multi-user.target'
        
        if [ ! -f "/etc/systemd/system/ddns.service" ] || [ ! -f "/etc/systemd/system/ddns.timer" ]; then
            echo -e "$service" >/etc/systemd/system/ddns.service
            echo -e "$timer" >/etc/systemd/system/ddns.timer
            systemctl enable --now ddns.service >/dev/null 2>&1
            systemctl enable --now ddns.timer >/dev/null 2>&1
        fi
    fi
}

set_ddns_run_interval() {
    read -rp "请输入新的 DDNS 运行间隔（分钟）： " interval
    if ! [[ "$interval" =~ ^[0-9]+$ ]]; then echo -e "${Error}无效输入！"; return 1; fi
    if grep -qiE "alpine" /etc/os-release; then
        local cron_time="*/$interval * * * * /bin/bash /etc/DDNS/DDNS >/dev/null 2>&1"
        if crontab -l | grep -q "/etc/DDNS/DDNS"; then (crontab -l | grep -v "/etc/DDNS/DDNS") | crontab -; fi
        (crontab -l; echo "$cron_time") | crontab -
    else
        systemctl stop ddns.timer && systemctl disable ddns.timer
        sed -i "s/OnUnitActiveSec=.*s/OnUnitActiveSec=${interval}m/" /etc/systemd/system/ddns.timer
        systemctl daemon-reload && systemctl enable --now ddns.timer
    fi
}

restart_ddns() {
    if grep -qiE "alpine" /etc/os-release; then
        current_cron=$(crontab -l | grep "/bin/bash /etc/DDNS/DDNS" || true)
        if [ -n "$current_cron" ]; then
            crontab -l | grep -v "/bin/bash /etc/DDNS/DDNS" | crontab -
            new_cron="${current_cron} >/dev/null 2>&1"
            (crontab -l; echo "$new_cron") | crontab -
        fi
    else
        systemctl restart ddns.service >/dev/null 2>&1
        systemctl restart ddns.timer >/dev/null 2>&1
    fi
    echo -e "${Info}DDNS 已重启！"
}

stop_ddns(){
    if grep -qiE "alpine" /etc/os-release; then
        crontab -l | grep -v "/bin/bash /etc/DDNS/DDNS >/dev/null 2>&1" | crontab -
    else
        systemctl stop ddns.service >/dev/null 2>&1
        systemctl stop ddns.timer >/dev/null 2>&1
    fi
    echo -e "${Info}DDNS 已停止！"
}

check_ddns_install(){
    if [ ! -f "/etc/DDNS/.config" ]; then
        cop_info
        echo -e "${Tip}DDNS 未安装，现在开始安装..."
        install_ddns
        set_cloudflare_api
        set_domain
        set_telegram_settings
        run_ddns
    else
        # 智能自我修复：如果发现旧版核心，自动无损替换，保留用户 Token
        if ! grep -q "write_log" /etc/DDNS/DDNS 2>/dev/null; then
            echo -e "${Tip}检测到您的系统底层仍然是旧版代码..."
            echo -e "${Info}正在自动平滑升级为 v2.6 核心，您的所有配置将原样保留！"
            install_ddns_core
            echo -e "${GREEN}升级成功！${NC}"
            sleep 2
        fi
        
        cop_info
        check_ddns_status
        if [[ "$ddns_status" == "running" ]]; then
            echo -e "${Info}DDNS：${GREEN}已安装${NC} 并 ${GREEN}已启动${NC}"
        else
            echo -e "${Tip}DDNS：${GREEN}已安装${NC} 但 ${RED}未启动${NC}"
        fi
        echo
        go_ahead
    fi
}

